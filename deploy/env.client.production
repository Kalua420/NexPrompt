# client/.env — production values for VPS
# Copy this to /var/www/nexprompt/client/.env on the VPS.
# This file is read at BUILD TIME by Vite — not at runtime.

VITE_API_URL=https://nexprompt.site
VITE_SOCKET_URL=https://nexprompt.site
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# URL of the admin app (used by user app sidebar for the Admin link)
VITE_ADMIN_URL=https://admin.nexprompt.site

# Used by the admin app to link back to the user-facing site
VITE_USER_APP_URL=https://nexprompt.site
