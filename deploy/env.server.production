# server/.env — production values for VPS
# Copy this to /var/www/nexprompt/server/.env on the VPS and fill in real values.

DATABASE_URL="mysql://nexprompt:CHANGE_THIS_DB_PASSWORD@localhost:3306/nexprompt"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_64_CHAR_RANDOM_STRING

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id

# AI provider keys — add via Admin panel after first login instead of here
GROQ_API_KEY=
SAMBANOVA_API_KEY=
ANTHROPIC_API_KEY=
OPENCODE_API_KEY=
GEMINI_API_KEY=

PORT=5000
NODE_ENV=production

# Both frontend origins — MUST include both domains
CLIENT_URL=https://nexprompt.site,https://admin.nexprompt.site

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Email (SendGrid recommended)
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@nexprompt.site
EMAIL_FROM_NAME=NexPrompt
