DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/nexprompt
# Generate a strong password: openssl rand -base64 24
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# AI Provider API Keys — DO NOT set these here.
# Add keys via the Admin panel → API Keys tab (stored securely in the database).
# Keys managed in the DB support multiple keys per provider, automatic failover, and load balancing.
GROQ_API_KEY=
SAMBANOVA_API_KEY=
ANTHROPIC_API_KEY=
OPENCODE_API_KEY=
GEMINI_API_KEY=

PORT=5000
# Comma-separated list of allowed frontend origins
# Production: https://nexprompt.site,https://admin.nexprompt.site
CLIENT_URL=http://localhost:5173,http://localhost:5174
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Email Configuration (choose one method)
# Option 1: SendGrid (Recommended for production)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@nexprompt.site
EMAIL_FROM_NAME=NexPrompt

# Option 2: SMTP (Gmail, Outlook, or custom SMTP server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Note: If neither is configured, emails will be logged to console only (dev mode)

VITE_GOOGLE_CLIENT_ID=your-client-id-here

# Admin creation — set before running node create_admin.js
ADMIN_PASSWORD=change_me_before_running_create_admin
TEST_PASSWORD=Test@123
