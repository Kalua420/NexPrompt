generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  passwordHash String?
  googleId     String?           @unique
  avatar       String?           @db.Text
  role         Role              @default(user)
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  resetToken   String?           @unique
  resetTokenExpiry DateTime?
  emailVerified Boolean          @default(false)
  verificationToken String?      @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  conversations Conversation[]
  prompts      Prompt[]
  favorites    Favorite[]
  payments     Payment[]
  creditBalance CreditBalance?
  creditTransactions CreditTransaction[]
  apiKeyUsageLogs ApiKeyUsageLog[]
}

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("New Conversation") @db.VarChar(500)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompts   Prompt[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  @@index([userId, updatedAt])
  @@index([deletedAt])
}

enum UseCase {
  chatbot
  coding
  writing
  image
  research
}

model Prompt {
  id             String       @id @default(cuid())
  title          String       @db.VarChar(500)
  content        String       @db.Text
  useCase        UseCase
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  favorites      Favorite[]
  generations    Generation[]
  creditTransactions CreditTransaction[]
  apiKeyUsageLogs ApiKeyUsageLog[]
  
  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([deletedAt])
  @@index([title(length: 255)])
  @@index([useCase])
}

model Generation {
  id        String   @id @default(cuid())
  content   String   @db.MediumText
  tokensUsed Int?
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  provider  String
  apiKeyId  String?
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeyUsageLogs ApiKeyUsageLog[]
  
  @@index([promptId])
  @@index([apiKeyId, createdAt])
  @@index([provider, createdAt])
}

enum TemplatePlan {
  free
  pro
  team
}

model Template {
  id              String   @id @default(cuid())
  title           String   @db.VarChar(500)
  description     String   @db.Text
  category        String
  content         String   @db.Text
  plan            TemplatePlan @default(free)
  featured        Boolean  @default(false)
  minCreditsRequired Int   @default(0)
  providers       Json?    @db.Json
  recommendedFor  Json?    @db.Json
  useCase         UseCase?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([category, featured])
  @@index([deletedAt])
  @@index([title(length: 255)])
  @@index([useCase])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, promptId])
  @@index([userId])
  @@index([promptId])
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model Payment {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Int
  currency          String      @default("INR")
  status            PaymentStatus @default(pending)
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  creditPackId      String?
  creditPack        CreditPack? @relation(fields: [creditPackId], references: [id], onDelete: SetNull)
  creditsGranted    Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  creditTransactions CreditTransaction[]
  
  @@index([userId, createdAt])
  @@index([status])
  @@index([creditPackId])
}

model CreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  bonus
  purchase
  usage
  refund
  adjustment
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Int
  description String   @db.Text
  metadata    Json?    @db.Json
  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  promptId    String?
  prompt      Prompt?  @relation(fields: [promptId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId, createdAt])
  @@index([type])
  @@index([paymentId])
  @@index([promptId])
}

model CreditPack {
  id            String    @id @default(cuid())
  name          String
  credits       Int
  bonusCredits  Int       @default(0)
  priceInPaise  Int
  isActive      Boolean   @default(true)
  displayOrder  Int       @default(0)
  popular       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  payments      Payment[]
  
  @@index([deletedAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  provider    String
  apiKey      String   @db.Text
  label       String?
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  lastUsedAt  DateTime?
  failCount   Int      @default(0)
  lastFailAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  failureLogs ApiKeyFailureLog[]
  usageLogs   ApiKeyUsageLog[]
  generations Generation[]
  
  @@index([provider, isActive, priority])
  @@index([provider, failCount])
}

model ApiKeyFailureLog {
  id         String   @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  provider   String
  errorCode  String?
  errorMsg   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([provider, createdAt])
}

model ApiKeyUsageLog {
  id           String   @id @default(cuid())
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  provider     String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId     String?
  prompt       Prompt?  @relation(fields: [promptId], references: [id], onDelete: SetNull)
  generationId String?
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  useCase      UseCase?
  tokensUsed   Int?
  success      Boolean  @default(true)
  errorMsg     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([apiKeyId, createdAt])
  @@index([provider, createdAt])
  @@index([userId, createdAt])
  @@index([success, createdAt])
  @@index([promptId])
  @@index([generationId, createdAt])
}
